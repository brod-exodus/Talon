# Supabase browser client. This key is public by design; enforce data access in server routes and RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server client. Keep this server-only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin login. Required in production.
TALON_ADMIN_PASSWORD=replace_with_a_strong_admin_password
TALON_SESSION_SECRET=replace_with_at_least_32_random_bytes

# Cron protection. Vercel cron requests should send Authorization: Bearer $CRON_SECRET.
CRON_SECRET=replace_with_a_long_random_bearer_secret

# Server-side GitHub token used by durable scrape jobs and watched-repo checks.
GITHUB_TOKEN=github_pat_or_classic_token

# Optional server-side Slack webhook used by automated watched-repo alerts.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
